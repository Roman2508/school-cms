{
  "kind": "collectionType",
  "collectionName": "event_posts",
  "info": {
    "singularName": "event-post",
    "pluralName": "event-posts",
    "displayName": "Event post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "body": {
      "type": "blocks"
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "end_date": {
      "type": "datetime"
    },
    "location": {
      "type": "string",
      "required": false
    }
  }
}
